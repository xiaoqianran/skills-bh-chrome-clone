#!/usr/bin/env bash
# bh-clone — Chrome session twin for browser-harness + chrome-devtools MCP
set -euo pipefail

# Resolve symlinks so `~/.local/bin/bh-clone` still finds the package root (cli/).
_SRC="${BASH_SOURCE[0]}"
while [[ -L "${_SRC}" ]]; do
  _DIR="$(cd "$(dirname "${_SRC}")" && pwd)"
  _SRC="$(readlink "${_SRC}")"
  [[ "${_SRC}" != /* ]] && _SRC="${_DIR}/${_SRC}"
done
ROOT="$(cd "$(dirname "${_SRC}")/.." && pwd)"
unset _SRC _DIR
# shellcheck source=../lib/common.sh
source "${ROOT}/lib/common.sh"

VERSION="${BH_CLONE_VERSION}"

usage() {
  cat <<USAGE
bh-clone ${VERSION} — cookie-only session twin (browser-harness + chrome-devtools)

Model:
  MAIN  = your daily Chrome (READ cookies only — never killed/rewritten)
  CLONE = automation Chrome on :${BH_CDP_PORT} (WRITE target)
  Flow  = MAIN --getAllCookies--> JSON --setCookies--> CLONE

Usage:
  bh-clone <command> [args]

Setup & session
  init [--with-profile]     First-time cookie-only setup (optional full rsync)
  sync [--with-profile]     READ main cookies → WRITE clone (default: cookie-only)
  ensure                    Start CLONE only if not running
  up [--sync]               ensure + harness env (+ optional sync)
  use clone|main            Switch browser-harness env file only (no process kill)

Clients
  mcp print|json            Print chrome-devtools MCP config (clone browserUrl)
  mcp install-grok          Write ~/.grok/config.toml for clone (no auto-connect)
  mcp check                 Verify clone CDP is up for MCP

Diagnostics
  doctor | status           Health for paths, CDP, optional probes, MCP config
  version                   Print version
  help                      This help

HARD RULES (MAIN browser):
  We never kill/restart main Chrome or rewrite its profile to "fix" sync.
  If export fails: Allow remote debugging in MAIN yourself, then re-run sync.
  Docs: docs/HARD_RULES.md  docs/COOKIE_ONLY.md

Environment (optional):
  BH_MAIN_PROFILE   default: ~/.config/google-chrome
  BH_CLONE_PROFILE  default: ~/.config/browser-harness-chrome-clone
  BH_CDP_PORT       default: 9333
  BH_COOKIE_FILE    default: ~/.config/browser-harness/main-cookies.json

Quick start:
  bh-clone init                 # cookie-only; may ask you to Allow on MAIN
  bh-clone up
  bh-clone mcp install-grok     # then restart Grok/MCP host
  export BU_CDP_URL=http://127.0.0.1:${BH_CDP_PORT}
  browser-harness <<'PY'
  print(page_info())
  PY
USAGE
}

cmd="${1:-help}"
shift || true

case "${cmd}" in
  init)
    bash "${ROOT}/scripts/init.sh" "$@"
    ;;
  sync)
    bash "${ROOT}/scripts/sync.sh" "$@"
    ;;
  ensure)
    bash "${ROOT}/scripts/ensure.sh" "$@"
    ;;
  up)
    bash "${ROOT}/scripts/up.sh" "$@"
    ;;
  use)
    target="${1:-}"
    case "${target}" in
      clone|isolated) bash "${ROOT}/scripts/use-clone.sh" ;;
      main)           bash "${ROOT}/scripts/use-main.sh" ;;
      *) die "usage: bh-clone use clone|main" ;;
    esac
    ;;
  mcp)
    bash "${ROOT}/scripts/mcp-config.sh" "$@"
    ;;
  doctor|status)
    bash "${ROOT}/scripts/doctor.sh" "$@"
    ;;
  version|--version|-V)
    echo "bh-chrome-clone ${VERSION}"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    die "unknown command: ${cmd}"
    ;;
esac
