#!/usr/bin/env bash
# bh-clone — Chrome session twin for browser-harness + chrome-devtools MCP
set -euo pipefail

# Resolve symlinks so `~/.local/bin/bh-clone` still finds the package root (cli/).
_SRC="${BASH_SOURCE[0]}"
while [[ -L "${_SRC}" ]]; do
  _DIR="$(cd "$(dirname "${_SRC}")" && pwd)"
  _SRC="$(readlink "${_SRC}")"
  [[ "${_SRC}" != /* ]] && _SRC="${_DIR}/${_SRC}"
done
ROOT="$(cd "$(dirname "${_SRC}")/.." && pwd)"
unset _SRC _DIR
# shellcheck source=../lib/common.sh
source "${ROOT}/lib/common.sh"

VERSION="${BH_CLONE_VERSION}"

usage() {
  cat <<USAGE
bh-clone ${VERSION} — cookie-only session twin (browser-harness + chrome-devtools)

Model:
  MAIN  = your daily Chrome (READ cookies only — never killed/rewritten)
  CLONE = automation Chrome(s) (WRITE targets)
  Flow  = MAIN --getAllCookies--> JSON --setCookies--> CLONE(s)

One clone is NOT multi-open. Parallel harness jobs need multiple clones
(or Browser Use cloud). See: bh-clone pool

Usage:
  bh-clone <command> [args]

Setup & session
  init [--with-profile]              First-time cookie-only setup
  sync [opts]                        READ main cookies → WRITE one clone
  ensure [--instance N] [--port P]   Start one CLONE
  up [--sync] [--instance N]         ensure + write env (BU_CDP_URL + BU_NAME)
  use clone|main                     Env only (main needs BH_ALLOW_USE_MAIN=1)

Multi-open (local)
  pool start <N>                     Start N workers w1..wN (ports 9333+)
  pool list | stop [name] | env | sync

Clients
  mcp print|json|install-grok|check  chrome-devtools → one clone URL

Diagnostics
  doctor | status | version | help

HARD RULES: never kill/restart MAIN Chrome. Docs: docs/HARD_RULES.md

Quick start (single):
  bh-clone init && bh-clone up
  source ~/.config/browser-harness/env
  browser-harness <<'PY'
  print(page_info())
  PY

Quick multi-open (two workers):
  bh-clone pool start 2
  bh-clone pool sync
  # shell A: source ~/.config/browser-harness/env.w1 && browser-harness ...
  # shell B: source ~/.config/browser-harness/env.w2 && browser-harness ...
USAGE
}

cmd="${1:-help}"
shift || true

case "${cmd}" in
  init)
    bash "${ROOT}/scripts/init.sh" "$@"
    ;;
  sync)
    bash "${ROOT}/scripts/sync.sh" "$@"
    ;;
  ensure)
    bash "${ROOT}/scripts/ensure.sh" "$@"
    ;;
  up)
    bash "${ROOT}/scripts/up.sh" "$@"
    ;;
  use)
    target="${1:-}"
    case "${target}" in
      clone|isolated) bash "${ROOT}/scripts/use-clone.sh" ;;
      main)           bash "${ROOT}/scripts/use-main.sh" ;;
      *) die "usage: bh-clone use clone|main" ;;
    esac
    ;;
  mcp)
    bash "${ROOT}/scripts/mcp-config.sh" "$@"
    ;;
  doctor|status)
    bash "${ROOT}/scripts/doctor.sh" "$@"
    ;;
  pool)
    bash "${ROOT}/scripts/pool.sh" "$@"
    ;;
  version|--version|-V)
    echo "bh-chrome-clone ${VERSION}"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    die "unknown command: ${cmd}"
    ;;
esac
